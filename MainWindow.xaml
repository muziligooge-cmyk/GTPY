<Window x:Class="BlueGlassMihomoClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BlueGlass Mihomo" Height="680" Width="950"
        WindowStartupLocation="CenterScreen" Background="{StaticResource AppBackground}"
        AllowsTransparency="False" WindowStyle="None" Loaded="OnLoaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="50" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/> <!-- Header -->
            <RowDefinition Height="60"/> <!-- Nav -->
            <RowDefinition Height="*"/>  <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="35" Height="35" Background="{StaticResource BrandBlue}" CornerRadius="10" Margin="0,0,15,0">
                    <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="White" Stretch="Uniform" Margin="7"/>
                </Border>
                <TextBlock Text="BlueGlass Client" FontSize="22" FontWeight="Bold" Foreground="#2D3748"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="12" Background="Transparent" BorderThickness="0" Width="40" Height="40" Click="OnMinimize"/>
                <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="12" Background="Transparent" BorderThickness="0" Width="40" Height="40" Click="OnClose" Foreground="#E53E3E"/>
            </StackPanel>
        </DockPanel>

        <!-- Navigation Tab Bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" WindowChrome.IsHitTestVisibleInChrome="True">
            <RadioButton x:Name="NavHome" Content="运行状态" Style="{StaticResource NavButton}" IsChecked="True" Checked="NavigateHome"/>
            <RadioButton x:Name="NavConfig" Content="配置导入" Style="{StaticResource NavButton}" Checked="NavigateConfig"/>
            <RadioButton x:Name="NavProxies" Content="节点选择" Style="{StaticResource NavButton}" Checked="NavigateProxies"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,10,0,0">
            <ContentControl x:Name="MainContentFrame"/>
        </Border>
    </Grid>
</Window>
